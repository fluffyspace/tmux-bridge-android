<resources>
    <!--
      Minimal launch theme. The real UI styling lives in Compose (see
      ui/theme/Theme.kt); this only covers the window before Compose draws.
      A framework parent avoids pulling in the Material Views library.
    -->
    <style name="Theme.TmuxBridge" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/teal_700</item>
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>
